# Telegram bot token (從 @BotFather 拿)
TELEGRAM_BOT_TOKEN=

# Claude OAuth refresh token
# 取得方式：本機跑過 `claude /login` 後，從 ~/.claude/.credentials.json
# 的 claudeAiOauth.refreshToken 複製出來
CLAUDE_REFRESH_TOKEN=

# 可選：Claude CLI 執行檔絕對路徑（PATH 找不到時才需要設）
# CLAUDE_BIN=/usr/local/bin/claude

# 可選：狀態檔（sessions.json / memory.json / photos/）存放目錄
# 預設 = bot.py 所在資料夾；Fly.io 部署設成 /data 指向 volume
# DATA_DIR=/data
